# Twitter账号配置（用于 twikit 登录，也可在前端 Settings 页面配置）
TWITTER_USERNAME=your_twitter_username
TWITTER_EMAIL=your_twitter_email
TWITTER_PASSWORD=your_twitter_password

# Twitter API配置（可选，官方付费 API）
TWITTER_API_KEY=your_api_key
TWITTER_API_SECRET=your_api_secret
TWITTER_ACCESS_TOKEN=your_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret
TWITTER_BEARER_TOKEN=your_bearer_token

# 发布模式: twikit(推荐，免费) / api(官方付费)
TWITTER_PUBLISH_MODE=twikit

# LLM配置（支持 OpenAI 兼容接口：GPT、Claude、Deepseek 等）
LLM_API_BASE=https://api.deepseek.com
LLM_API_KEY=your_llm_api_key
LLM_MODEL=deepseek-chat

# 代理配置（用于访问 Twitter，Docker 内使用 host.docker.internal）
PROXY_URL=http://host.docker.internal:7890

# 服务配置
BACKEND_PORT=8000
FRONTEND_PORT=3000

# 数据库配置
DATABASE_URL=sqlite+aiosqlite:///./data/haa.db

# 上传文件配置
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760
